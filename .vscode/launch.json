{
    // 使用 IntelliSense 了解相关属性。
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "QMT Server (trading, 默认普通户)",
            "type": "debugpy",
            "request": "launch",
            "module": "qmt_bridge.server.cli",
            "args": [
                "--port",
                "8080",
                "--log-level",
                "debug",
                "--trading"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "QMT Server (trading, 默认信用户)",
            "type": "debugpy",
            "request": "launch",
            "module": "qmt_bridge.server.cli",
            "args": [
                "--port",
                "8080",
                "--log-level",
                "debug",
                "--default-account",
                "credit"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
